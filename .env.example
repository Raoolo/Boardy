# Anthropic API key (one key, all models — Sonnet/Haiku/etc.)
# Get one at https://console.anthropic.com — separate from claude.ai Pro.
ANTHROPIC_API_KEY=sk-ant-...

# BoardGameGeek XML API2 bearer token (required for etl/backfill_v2.py
# AND for the post-write _backfill_bgg_media hook that fills thumbnail/
# image URLs after add_game/add_to_wishlist).
# Register an app at https://boardgamegeek.com/using_the_xml_api to obtain one.
# Without it the BGG API returns HTTP 401 (Cloudflare gate, since 2026-04).
BGG_API_TOKEN=...

# Tavily — backs the web_search tool. 1000 free searches/month at
# https://tavily.com. Without this web_search returns an error.
TAVILY_API_KEY=tvly-...

# DeepSeek API key — used by the /library/filter "smart filter" endpoint
# (natural-language → filter spec via DeepSeek, ~$0.001/query). Same key
# also drives LLM_PROVIDER=deepseek when you want the main chat to run
# on it instead of Anthropic. Get one at https://platform.deepseek.com.
DEEPSEEK_API_KEY=...

# ─── LLM provider switch ─────────────────────────────────────────────────
# `anthropic` (default), `deepseek`, or `ollama`. Per-request, no restart.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6                 # optional override

# ─── Docker / self-host ──────────────────────────────────────────────────
# Override DB path. docker-compose.yml sets this to point at the persistent
# named volume. Leave unset for local dev → falls back to <repo>/data/boardy.db.
# BOARDY_DB=/data/boardy.db

# Cloudflare Tunnel token — needed ONLY by `docker compose --profile tunnel`.
# Generated in the CF dashboard: Zero Trust → Networks → Tunnels → Create →
# copy the long token from the "install connector" page. See CLAUDE.md
# "Deploy / Self-host" for the 4-step setup.
# CF_TUNNEL_TOKEN=eyJhIjoi...

# ─── Auth (v7+, owner login) ─────────────────────────────────────────────
# Chiave segreta per firmare il cookie di sessione owner. OBBLIGATORIA in
# produzione (senza questa, l'app fa crash al primo /auth/login). Generala con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Ruotare la chiave invalida TUTTI i cookie esistenti (logout forzato).
# BOARDY_SESSION_SECRET=...

# Imposta a "1" SOLO in produzione su HTTPS — il cookie diventa Secure
# (browser rifiuta su HTTP). Lascia commentato in dev locale (http://localhost).
# BOARDY_COOKIE_SECURE=1

# ─── Telegram bot (opzionale) ────────────────────────────────────────────
# Client mobile per Boardy: thin wrapper su POST /chat. Lancia con
#   uv run python -m bot.telegram_bot
# (o `docker compose -f deploy/docker-compose.yml --profile telegram up -d`).
#
# 1) Token del bot — crealo via @BotFather su Telegram.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#
# 2) Allow-list owner: user_id Telegram (interi) separati da virgola.
#    Chi NON e' in lista parla con Boardy in guest mode (read-only).
#    Scopri il tuo user_id mandando /whoami al bot dopo il primo start.
# TELEGRAM_OWNER_IDS=12345678,87654321
#
# 3) Credenziali con cui il bot fa login a Boardy per i messaggi degli owner.
#    Usa un account creato con `uv run python etl/create_user.py create`.
#    Se mancano, il bot funziona ma SOLO in guest mode anche per gli owner.
# BOARDY_BOT_USERNAME=raulo
# BOARDY_BOT_PASSWORD=...
#
# 4) URL base di Boardy. Default OK in locale; in Docker compose il valore
#    e' impostato dal compose (http://boardy:8765 sulla rete interna).
# BOARDY_BASE_URL=http://127.0.0.1:8765
